# Copy to .env and fill in real values. Never commit .env.

# Redis connection used for the step-executor stream + consumer groups.
REDIS_URL=redis://localhost:6379/0

# LLM gateway credentials (used once the agent loop lands in R4).
ANTHROPIC_API_KEY=sk-ant-...your-key-here

# Per-session token/cost budget enforced by the budget meter (R3+).
RATCHET_DEFAULT_SESSION_BUDGET_USD=2.00

# Comma-separated broker backend selector: redis | rabbitmq | kafka.
RATCHET_BROKER=redis
